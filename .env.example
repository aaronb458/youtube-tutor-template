# ─── REQUIRED FOR PAID PATH (cloud) ──────────────────────────────────────────
# Copy this file to .env and fill in real values. Never commit .env.

# Supabase — get from supabase.com after creating a project
# Settings → API → "Project URL" and "anon public" key
SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
SUPABASE_KEY=YOUR-SUPABASE-ANON-KEY

# OpenAI or OpenRouter — for generating embeddings (the "search brain")
# Easiest: openrouter.ai → API Keys → Create Key
# Then both keys point at the same place via this single var.
OPENROUTER_API_KEY=sk-or-v1-YOUR-KEY-HERE

# Deepgram — only used to transcribe videos that don't have YouTube captions
# Sign up at deepgram.com → get $200 free credits → API Keys → Create
# Optional: if you skip this, the scraper falls back to free YouTube captions only.
DEEPGRAM_API_KEY=YOUR-DEEPGRAM-KEY

# ─── OPTIONAL — only for restricting the MCP server to specific channels ─────
# Leave empty to search every channel in your Supabase.
# To filter: comma-separated channel UUIDs (look them up in Supabase Table Editor → channels)
# CHANNEL_FILTER=
